# frozen_string_literal: true

class <%= name %> < Lumina::LuminaModel
<% if belongs_to_org -%>
  include Lumina::BelongsToOrganization
<% end -%>
<% if soft_deletes -%>
  include Discard::Model
<% end -%>
<% if audit_trail -%>
  include Lumina::HasAuditTrail
<% end -%>

  # ---------------------------------------------------------------
  # Query Builder configuration
  # ---------------------------------------------------------------

<% unless filter_cols.empty? -%>
  lumina_filters <%= filter_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless sort_cols.empty? -%>
  lumina_sorts <%= sort_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless field_cols.empty? -%>
  lumina_fields <%= field_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless include_cols.empty? -%>
  lumina_includes <%= include_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>

  # ---------------------------------------------------------------
  # Validation rules (pipe-delimited, Laravel-compatible)
  # ---------------------------------------------------------------

<% unless validation_rules.empty? -%>
  lumina_validation_rules(
<%= validation_rules.map { |k, v| "    #{k}: '#{v}'" }.join(",\n") %>
  )
<% end -%>

  lumina_store_rules(
    '*': { <%= columns.reject { |c| c[:name] == "organization_id" }.map { |c| "#{c[:name]}: :required" }.join(", ") %> }
  )

  lumina_update_rules(
    '*': { <%= columns.reject { |c| c[:name] == "organization_id" }.map { |c| "#{c[:name]}: :nullable" }.join(", ") %> }
  )
<% if owner_relation -%>

  # ---------------------------------------------------------------
  # Organization scoping (relationship path to the org owner)
  # ---------------------------------------------------------------

  lumina_owner '<%= owner_relation %>'
<% end -%>

  # ---------------------------------------------------------------
  # Relationships
  # ---------------------------------------------------------------

<% columns.select { |c| c[:type] == "references" && c[:foreign_model] }.each do |col| -%>
<% relation_name = col[:name].sub(/_id\z/, "") -%>
<% next if belongs_to_org && col[:foreign_model] == "Organization" -%>
  belongs_to :<%= relation_name %>, class_name: "<%= col[:foreign_model] %>"
<% end -%>
end
