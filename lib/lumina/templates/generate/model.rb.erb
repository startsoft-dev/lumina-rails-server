# frozen_string_literal: true

class <%= name %> < Lumina::LuminaModel
<% if belongs_to_org -%>
  include Lumina::BelongsToOrganization
<% end -%>
<% if soft_deletes -%>
  include Discard::Model
<% end -%>
<% if audit_trail -%>
  include Lumina::HasAuditTrail
<% end -%>

  # ---------------------------------------------------------------
  # Query Builder configuration
  # ---------------------------------------------------------------

<% unless filter_cols.empty? -%>
  lumina_filters <%= filter_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless sort_cols.empty? -%>
  lumina_sorts <%= sort_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless field_cols.empty? -%>
  lumina_fields <%= field_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>
<% unless include_cols.empty? -%>
  lumina_includes <%= include_cols.map { |c| ":#{c}" }.join(", ") %>
<% end -%>

  # ---------------------------------------------------------------
  # Validation (ActiveModel — use allow_nil: true for all validators)
  # ---------------------------------------------------------------

<% unless validation_rules.empty? -%>
<% validation_rules.each do |field, rule| -%>
<% # Convert pipe-delimited rules to ActiveModel validates calls -%>
<% parts = rule.split("|").reject { |p| %w[required nullable sometimes].include?(p) } -%>
<% validations = [] -%>
<% parts.each do |part| -%>
<%   if part.start_with?("max:") -%>
<%     validations << "length: { maximum: #{part.sub('max:', '')} }" -%>
<%   elsif part.start_with?("min:") -%>
<%     validations << "length: { minimum: #{part.sub('min:', '')} }" -%>
<%   elsif part == "boolean" -%>
<%     validations << "inclusion: { in: [true, false] }" -%>
<%   elsif part.start_with?("in:") -%>
<%     vals = part.sub("in:", "").split(",").map { |v| "\"#{v}\"" }.join(", ") -%>
<%     validations << "inclusion: { in: [#{vals}] }" -%>
<%   elsif part == "integer" -%>
<%     validations << "numericality: { only_integer: true }" -%>
<%   end -%>
<% end -%>
<% unless validations.empty? -%>
  validates :<%= field %>, <%= validations.join(", ") %>, allow_nil: true
<% end -%>
<% end -%>
<% end -%>

  # ---------------------------------------------------------------
  # Field permissions are controlled by the policy.
  # See: app/policies/<%= name.underscore %>_policy.rb
  # ---------------------------------------------------------------

  # ---------------------------------------------------------------
  # Relationships
  # (Organization scoping is auto-detected from belongs_to associations)
  # ---------------------------------------------------------------

<% columns.select { |c| c[:type] == "references" && c[:foreign_model] }.each do |col| -%>
<% relation_name = col[:name].sub(/_id\z/, "") -%>
<% next if belongs_to_org && col[:foreign_model] == "Organization" -%>
  belongs_to :<%= relation_name %>, class_name: "<%= col[:foreign_model] %>"
<% end -%>
end
